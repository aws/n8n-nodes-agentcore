{
  "name": "@aws/n8n-nodes-agentcore",
  "version": "0.1.1",
  "description": "n8n community node for Amazon Bedrock AgentCore harness. Run production-grade AI agents with isolated microVMs, real browsers, real code execution, and persistent memory — directly from your n8n workflows.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "aws",
    "bedrock",
    "agentcore",
    "harness",
    "ai",
    "agent",
    "llm"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/aws/n8n-nodes-agentcore",
  "author": {
    "name": "Amazon Web Services"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aws/n8n-nodes-agentcore.git"
  },
  "bugs": {
    "url": "https://github.com/aws/n8n-nodes-agentcore/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier nodes credentials --write",
    "format:check": "prettier nodes credentials --check",
    "lint": "eslint --ext .ts,.json nodes credentials package.json",
    "lintfix": "eslint --ext .ts,.json nodes credentials package.json --fix",
    "security:audit": "npm audit --audit-level=high --omit=dev",
    "secrets:check": "secretlint \"**/*\" --secretlintignore .secretlintignore",
    "prepublishOnly": "npm run build && npm run lint && npm run typecheck"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AgentCoreApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AgentCoreHarness/AgentCoreHarness.node.js"
    ]
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.2.0",
    "secretlint": "^9.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agentcore": "^3.1075.0",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1075.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
