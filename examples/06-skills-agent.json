{
	"name": "AgentCore — Skills (AWS + Git + S3)",
	"nodes": [
		{
			"parameters": {},
			"id": "1",
			"name": "Manual Trigger",
			"type": "n8n-nodes-base.manualTrigger",
			"typeVersion": 1,
			"position": [240, 300]
		},
		{
			"parameters": {
				"agentName": "skilled_agent",
				"modelProvider": "bedrock",
				"modelId": "global.anthropic.claude-sonnet-4-6",
				"systemPrompt": "You are an AWS solutions engineer. Use your skills to follow current best practices.",
				"prompt": "Draft a serverless architecture for a high-traffic image upload pipeline. Follow our company style guide.",
				"skills": {
					"skill": [
						{
							"source": "awsSkills",
							"paths": "core-skills/aws-serverless, specialized-skills/storage-skills/*"
						},
						{
							"source": "git",
							"gitUrl": "https://github.com/anthropics/skills",
							"gitPath": "skills/docx"
						},
						{
							"source": "s3",
							"s3Uri": "s3://my-skills-bucket/skills/company-style/"
						}
					]
				},
				"additionalOptions": {
					"timeoutSeconds": 300
				}
			},
			"id": "2",
			"name": "Skilled Agent",
			"type": "@aws/n8n-nodes-agentcore.agentCoreHarness",
			"typeVersion": 1,
			"position": [480, 300],
			"credentials": { "agentCoreApi": { "id": "1", "name": "AgentCore creds" } }
		}
	],
	"connections": {
		"Manual Trigger": {
			"main": [[{ "node": "Skilled Agent", "type": "main", "index": 0 }]]
		}
	}
}
